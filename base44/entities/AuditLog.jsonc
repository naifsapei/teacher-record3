      "type": "string",
      "description": "\u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u0633\u0627\u0628\u0642"
    },
    "new_role": {
      "type": "string",
      "description": "\u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u062c\u062f\u064a\u062f"
    },
    "action": {
      "type": "string",
